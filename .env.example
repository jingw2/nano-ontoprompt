# production 环境下默认凭据 (SECRET_KEY/FIRST_ADMIN_PASSWORD/MINIO_*/ENCRYPTION_KEY) 必须修改, 否则启动报错
ENVIRONMENT=development
DATABASE_URL=postgresql://ontoprompt:ontoprompt@db:5432/ontoprompt
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-random-32-char-string
ENCRYPTION_KEY=
FIRST_ADMIN_USER=admin
FIRST_ADMIN_PASSWORD=admin123
UPLOADS_DIR=/uploads

# LiteLLM Proxy — 填入需要的 provider key，不用的留空即可
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=
# LiteLLM Admin UI (passed via docker-compose environment, not DATABASE_URL)
LITELLM_MASTER_KEY=sk-master-change-me
LITELLM_SALT_KEY=sk-salt-change-me
UI_USERNAME=admin
UI_PASSWORD=change-me-litemll-admin-password
# Note: LiteLLM uses its own DB (litellm) — see docker-compose.yml litellm service

# v2 — Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ontoprompt123

# v2 — MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# v2 — ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8001

